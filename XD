st.title("🎵 K-Pop Translator AI")
st.subheader("System inteligentnego tłumaczenia piosenek i nauki języka koreańskiego")
st.write("---")

# 2. BEZPIECZNE POBIERANIE KLUCZA Z USTAWIEŃ STREAMLIT CLOUD (Twój świetny pomysł!)
GEMINI_KEY = st.secrets["GOOGLE_API_KEY"]
client = genai.Client(api_key=GEMINI_KEY)

# 3. Definicja promptu systemowego (Ulepszona struktura)
SYSTEM_PROMPT = """
Jesteś ekspertem języka koreańskiego i kultury K-Pop.
Odpowiadaj zawsze po polsku, używając ładnego formatowania Markdown.

Dla podanego tekstu piosenki wygeneruj wynik w 3 czytelnych sekcjach:

### 🎤 1. Tłumaczenie
Podaj dokładne, ale brzmiące naturalnie tłumaczenie tekstu na język polski.

### 📚 2. Słówka do nauki
Wybierz 5-7 najważniejszych słówek z tekstu. Zapisz je w formie listy wypunktowanej:
* **Hangeul** - *wymowa* - znaczenie

### 💡 3. Ciekawostki językowe
Wyjaśnij jedną lub dwie ciekawe konstrukcje gramatyczne, slang lub nawiązania kulturowe użyte w tekście.
"""

# 4. Tworzenie interfejsu użytkownika (2 kolumny)
col1, col2 = st.columns(2)

with col1:
    st.markdown("### 📥 Wklej tekst piosenki")
    user_input = st.text_area(
        "Wklej oryginalny tekst po koreańsku (Hangeul):", 
        height=400,
        placeholder="Wklej tekst piosenki tutaj..."
    )
    
    run_button = st.button("🚀 Analizuj z Gemini AI", use_container_width=True)

with col2:
    st.markdown("### 📤 Wynik analizy")
    
    if run_button:
        if not user_input.strip():
            st.error("Błąd: Najpierw wklej tekst piosenki do okienka po lewej stronie!")
        else:
            with st.spinner("AI analizuje tekst i przygotowuje słówka..."):
                
                max_retries = 3
                response = None
                
                # Próba wysłania zapytania (max 3 podejścia - ochrona przed błędem 503)
                for attempt in range(max_retries):
                    try:
                        # Używamy stabilnego modelu 1.5-flash
                        response = client.models.generate_content(
                            model='gemini-1.5-flash',
                            contents=user_input,
                            config=types.GenerateContentConfig(
                                system_instruction=SYSTEM_PROMPT,
                                temperature=0.2
                            )
                        )
                        break  # Sukces! Przerwanie pętli
                    except Exception as e:
                        if "503" in str(e) and attempt < max_retries - 1:
                            time.sleep(1.5)  # Serwer zajęty, czekamy i próbujemy znowu
                            continue
                        else:
                            # Jeśli to inny błąd niż przeciążenie, wypisz go
                            st.error(f"Wystąpił błąd komunikacji: {e}")
                            break
                
                # Renderowanie wyniku w zależności od odpowiedzi serwera
                if response:
                    st.success("Gotowe!")
                    # Używamy st.markdown, aby pogrubienia i listy od AI wyglądały pięknie!
                    st.markdown(response.text)
                elif not response:
                    st.warning("⚠️ Usługa analizy jest w tej chwili przeciążona (Błąd 503). Serwery Google nie odpowiadają. Spróbuj ponownie za moment.")
